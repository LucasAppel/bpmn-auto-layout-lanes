<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:signavio="http://www.signavio.com" id="Definitions_LaneItMultiple" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_LaneItMultiple" isExecutable="true">
    <bpmn:laneSet id="LaneSet_LaneItMultiple">
      <bpmn:lane id="Lane_A" name="A">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_1">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_2">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_1">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="End_1" />
    <bpmn:textAnnotation id="ItSystem_1">
      <bpmn:extensionElements>
        <signavio:signavioType dataObjectType="IT-System" />
      </bpmn:extensionElements>
      <bpmn:text>ERP A</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="ItSystem_2">
      <bpmn:extensionElements>
        <signavio:signavioType dataObjectType="IT-System" />
      </bpmn:extensionElements>
      <bpmn:text>ERP B</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="ItSystem_3">
      <bpmn:extensionElements>
        <signavio:signavioType dataObjectType="IT-System" />
      </bpmn:extensionElements>
      <bpmn:text>ERP C</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" associationDirection="None" sourceRef="Task_1" targetRef="ItSystem_1" />
    <bpmn:association id="Association_2" associationDirection="None" sourceRef="Task_1" targetRef="ItSystem_2" />
    <bpmn:association id="Association_3" associationDirection="None" sourceRef="Task_1" targetRef="ItSystem_3" />
  </bpmn:process>
</bpmn:definitions>
